generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  GOD
  MODERATOR
  CLIENT
  OWNER
  DELIVERYMAN
  CASHIER
}

enum Status {
  CREATED
  COOKING
  FROM_DELIVERYMAN
  DELIVERED
}

model User {
  idUser   String  @id @default(cuid()) @map("id_user")
  email    String  @unique
  phone    String? @unique
  password String

  surname    String?
  name       String?
  patronymic String?

  // Email verification
  verificationToken String? @default(cuid()) @map("verification_token")

  // SMS OTP verification
  otpCode      String?   @map("otp_code")
  otpExpiresAt DateTime? @map("otp_expires_at")

  role      UserRole[]
  shifts    Shift[]
  address   AddressUser[]
  orders         Order[] @relation("ClientOrders")
  deliveryOrders Order[] @relation("CourierOrders")
  organizations Organization[]
  cashierRestaurant Restaurant? @relation("CashierRestaurant", fields: [cashierRestaurantId], references: [idRestaurant])

  cashierRestaurantId String? @map("cashier_restaurant_id")

  @@index([cashierRestaurantId])
  @@map("users")
}

model UserRole {
   idUserRole String   @id @default(cuid()) @map("id_user_role")
   role       Role

   userId     String @map("user_id")
   user       User   @relation(fields: [userId], references: [idUser], onDelete: Cascade)

   @@unique([userId, role])
   @@map("user_roles")
 }

model Shift {
  idShift String @id @default(cuid()) @map("id_shift")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [idUser])

  createAt DateTime  @default(now()) @map("created_at")
  stopAt   DateTime? @map("stop_at")

  @@map("shifts")
}

model Address {
  idAddress String @id @default(cuid()) @map("id_address")

  address   String
  entrance Int?
  doorphone String?
  flat String?
  floor String?
  comment String?

  cordinatY Float
  cordinatX Float

  addressUser AddressUser[]
  addressRestaraunt AddressRestaraunt?
  orders Order[]

  @@map("addresses")
}

model AddressUser{
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [idUser], onDelete: Cascade)

  addressId String @map("address_id")
  address   Address   @relation(fields: [addressId], references: [idAddress], onDelete: Cascade)

  @@unique([userId, addressId])
  @@map("address_user")
}

model AddressRestaraunt{
  restaurantId String @unique @map("restataunt_id")
  restaurant Restaurant @relation(fields: [restaurantId], references: [idRestaurant], onDelete: Cascade)

  addressId String @unique @map("address_id")
  address   Address   @relation(fields: [addressId], references: [idAddress], onDelete: Cascade)

  @@unique([restaurantId, addressId])
  @@map("address_restaurant")
}

model Order {
  idOrder String @id @default(cuid()) @map("id_order")

  payStatus Boolean @default(false) @map("pay_status")
  status    Status
  weight    Float? @map("weight")

  createAt DateTime @default(now()) @map("created_at")

  clientId     String @map("client_id")
  deliverymanId String? @map("deliveryman_id")
  restarauntId String @map("restaraunt_id")
  addressId    String @map("address_id")

  address    Address    @relation(fields: [addressId], references: [idAddress])
  client     User       @relation("ClientOrders", fields: [clientId], references: [idUser])
  deliveryman User?     @relation("CourierOrders", fields: [deliverymanId], references: [idUser])
  restaraunt Restaurant @relation(fields: [restarauntId], references: [idRestaurant])
  products   OrderProduct[]

  @@map("orders")
}

model Product {
  idProduct String @id @default(cuid()) @map("id_product")

  name        String
  price       Float
  timeCooking Int?    @map("time_cooking")
  calories    Float?
  description String?

  orders     OrderProduct[]

  restaurantId String     @map("restaurant_id")
  restaurant   Restaurant @relation(fields: [restaurantId], references: [idRestaurant])

  @@map("products")
}

model OrderProduct {
  idOrderProduct String @id @default(cuid()) @map("id_order_product")

  quantity Int @default(1)
  price    Float

  orderId   String  @map("order_id")
  productId String  @map("product_id")

  order   Order   @relation(fields: [orderId], references: [idOrder], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [idProduct])

  @@unique([orderId, productId])
  @@map("order_products")
}

model Organization {
  idOrganization String @id @default(cuid()) @map("id_organization")

  name  String  @unique
  email String  @unique
  phone String?

  restaurants Restaurant[]

  ownerId String @map("owner_id")
  owner   User   @relation(fields: [ownerId], references: [idUser])

  @@index([ownerId])
  @@map("organizations")
}

model Restaurant {
  idRestaurant String @id @default(cuid()) @map("id_restaurant")

  name        String
  description String?
  cuisine     String?

  timeOpened DateTime @db.Time(0) @map("time_opened")
  timeClosed DateTime @db.Time(0) @map("time_closed")

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [idOrganization])

  address AddressRestaraunt?

  products Product[]
  orders   Order[]
  cashiers User[] @relation("CashierRestaurant")

  @@map("restaurants")
}
